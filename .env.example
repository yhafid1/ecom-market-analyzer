# Copy this file to .env and fill in your values
# Never commit .env to git

# ── PostgreSQL ──────────────────────────────
DB_NAME=ecomm_intelligence
DB_USER=ecomm_user
DB_PASSWORD=changeme
DB_HOST=db          # use 'localhost' if running outside Docker
DB_PORT=5432

# ── eBay Developer API ───────────────────────
# Register free at: https://developer.ebay.com
EBAY_APP_ID=your_ebay_app_id_here
EBAY_CERT_ID=your_ebay_cert_id_here
EBAY_CLIENT_SECRET=your_ebay_client_secret_here

# ── Reddit API ───────────────────────────────
# Register free at: https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=your_reddit_client_id_here
REDDIT_CLIENT_SECRET=your_reddit_client_secret_here
REDDIT_USER_AGENT=ecomm-intelligence/1.0

# ── Rainforest API (Amazon BSR) ──────────────
# Free tier at: https://www.rainforestapi.com
RAINFOREST_API_KEY=your_rainforest_key_here

# ── App ──────────────────────────────────────
STREAMLIT_PORT=8501
PIPELINE_SCHEDULE_HOUR=6   # hour (UTC) to run daily pipeline
